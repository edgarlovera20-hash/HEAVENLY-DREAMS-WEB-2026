# HD-WEB Environment Template
# Copy to .env and fill in real values. Never commit .env to version control.

NODE_ENV=development
APP_NAME=HD-WEB
APP_PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# HD-CORE dependency resolution (local | registry)
HD_CORE_MODE=local

# n8n Automation (server-side only, never expose to browser)
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_WEB_SECRET=replace-with-a-strong-secret

# Rate Limiting
RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info
